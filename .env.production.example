# Production Environment Configuration

APP_NAME=VELOZZ
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://velozz.digital
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# URLs
ASSET_URL=https://velozz.digital
ADMIN_URL=https://app.velozz.digital
CLIENT_URL_BASE=https://{subdomain}.velozz.digital

# Maintenance
APP_MAINTENANCE_DRIVER=file

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=velozz_production
DB_USERNAME=velozz
DB_PASSWORD=STRONG_PASSWORD_HERE

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=REDIS_STRONG_PASSWORD
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# Session & Cache
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.velozz.digital
SESSION_SECURE_COOKIE=true

CACHE_STORE=redis
CACHE_PREFIX=velozz

# Queue
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

# Broadcasting (Reverb)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=velozz
REVERB_APP_KEY=GENERATE_RANDOM_KEY
REVERB_APP_SECRET=GENERATE_RANDOM_SECRET
REVERB_HOST=ws.velozz.digital
REVERB_PORT=443
REVERB_SCHEME=https

# Mail (Amazon SES)
MAIL_MAILER=ses
MAIL_FROM_ADDRESS=noreply@velozz.digital
MAIL_FROM_NAME="${APP_NAME}"
AWS_ACCESS_KEY_ID=YOUR_AWS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET
AWS_DEFAULT_REGION=us-east-1
AWS_SES_REGION=us-east-1

# Filesystem
FILESYSTEM_DISK=s3
AWS_BUCKET=velozz-production
AWS_URL=https://velozz-production.s3.amazonaws.com

# Scout (Meilisearch)
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

# Multi-Tenancy
TENANCY_ENABLED=true
TENANCY_DOMAIN=velozz.digital

# Filament
FILAMENT_FILESYSTEM_DISK=public

# Stripe (Production)
STRIPE_KEY=pk_live_YOUR_KEY
STRIPE_SECRET=sk_live_YOUR_SECRET
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
CASHIER_CURRENCY=eur

# Z-API WhatsApp
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=

# Security
BCRYPT_ROUNDS=12

# Performance
OCTANE_SERVER=swoole
